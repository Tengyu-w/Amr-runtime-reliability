<?xml version="1.0"?>
<sdf version="1.10">
  <model name="reliability_amr">
    <self_collide>false</self_collide>

    <link name="base_link">
      <pose>0 0 0.23 0 0 0</pose>
      <inertial>
        <mass>18.0</mass>
        <inertia>
          <ixx>0.42</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.56</iyy>
          <iyz>0.0</iyz>
          <izz>0.78</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.72 0.52 0.28</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.72 0.52 0.28</size>
          </box>
        </geometry>
        <material>
          <ambient>0.10 0.16 0.18 1</ambient>
          <diffuse>0.10 0.30 0.34 1</diffuse>
          <specular>0.20 0.20 0.20 1</specular>
        </material>
      </visual>
    </link>

    <link name="left_wheel">
      <pose>0 0.31 0.16 -1.57079632679 0 0</pose>
      <inertial>
        <mass>1.4</mass>
        <inertia>
          <ixx>0.012</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.012</iyy>
          <iyz>0.0</iyz>
          <izz>0.018</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>0 -0.31 0.16 -1.57079632679 0 0</pose>
      <inertial>
        <mass>1.4</mass>
        <inertia>
          <ixx>0.012</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.012</iyy>
          <iyz>0.0</iyz>
          <izz>0.018</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.16</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="caster_link">
      <pose>-0.30 0 0.08 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.004</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.004</iyy>
          <iyz>0.0</iyz>
          <izz>0.004</izz>
        </inertia>
      </inertial>
      <collision name="caster_collision">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>
      </collision>
      <visual name="caster_visual">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.03 0.03 0.03 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="laser_link">
      <pose>0.22 0 0.44 0 0 0</pose>
      <inertial>
        <mass>0.35</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.001</iyy>
          <iyz>0.0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
      <sensor name="scan" type="gpu_lidar">
        <topic>/scan</topic>
        <update_rate>12</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265359</min_angle>
              <max_angle>3.14159265359</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.10</min>
            <max>8.0</max>
            <resolution>0.02</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </link>

    <link name="depth_camera_link">
      <pose>0.34 0 0.52 0 0 0</pose>
      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.001</iyy>
          <iyz>0.0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <collision name="depth_camera_collision">
        <geometry>
          <box>
            <size>0.12 0.08 0.06</size>
          </box>
        </geometry>
      </collision>
      <visual name="depth_camera_visual">
        <geometry>
          <box>
            <size>0.12 0.08 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.04 1</ambient>
          <diffuse>0.08 0.10 0.16 1</diffuse>
        </material>
      </visual>
      <sensor name="depth_camera" type="depth_camera">
        <topic>/depth_image</topic>
        <update_rate>8</update_rate>
        <camera>
          <horizontal_fov>1.0471975512</horizontal_fov>
          <image>
            <width>160</width>
            <height>120</height>
            <format>R_FLOAT32</format>
          </image>
          <clip>
            <near>0.18</near>
            <far>8.0</far>
          </clip>
        </camera>
      </sensor>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
        </limit>
      </axis>
    </joint>

    <joint name="caster_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_link</child>
    </joint>

    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>laser_link</child>
    </joint>

    <joint name="depth_camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>depth_camera_link</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.62</wheel_separation>
      <wheel_radius>0.16</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_velocity>0.55</max_linear_velocity>
      <min_linear_velocity>-0.20</min_linear_velocity>
      <max_angular_velocity>1.2</max_angular_velocity>
      <min_angular_velocity>-1.2</min_angular_velocity>
      <max_linear_acceleration>0.8</max_linear_acceleration>
      <min_linear_acceleration>-0.8</min_linear_acceleration>
      <max_angular_acceleration>1.8</max_angular_acceleration>
      <min_angular_acceleration>-1.8</min_angular_acceleration>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher"/>

    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <dimensions>2</dimensions>
      <odom_topic>/ground_truth/odom</odom_topic>
      <tf_topic>/ground_truth/tf</tf_topic>
      <odom_publish_frequency>10</odom_publish_frequency>
    </plugin>
  </model>
</sdf>
